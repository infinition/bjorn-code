{
    "name": "bjorn-code",
    "displayName": "Bjorn Code",
    "description": "Bi-directional synchronization for Bjorn Cyberviking project",
    "version": "2.0.0",
    "publisher": "nephystos",
    "repository": {
        "type": "git",
        "url": "https://github.com/infinition/BjornCode.git"
    },
    "bugs": {
        "url": "https://github.com/infinition/BjornCode/issues"
    },
    "homepage": "https://github.com/infinition/BjornCode#readme",
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished",
        "onView:bjornCodeExplorer",
        "onCommand:bjorn-code.openView"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "title": "Bjorn Code: Push to Remote",
                "command": "bjorn-code.syncNow",
                "icon": "$(cloud-upload)"
            },
            {
                "title": "Bjorn Code: Full Push (scan all files)",
                "command": "bjorn-code.fullSync",
                "icon": "$(repo-push)"
            },
            {
                "title": "Bjorn Code: Connect",
                "command": "bjorn-code.connect",
                "icon": "$(plug)"
            },
            {
                "title": "Bjorn Code: Disconnect",
                "command": "bjorn-code.disconnect",
                "icon": "$(debug-disconnect)"
            },
            {
                "title": "Bjorn Code: Toggle Connection",
                "command": "bjorn-code.toggleConnection",
                "icon": "$(plug)"
            },
            {
                "title": "Bjorn Code: Connected",
                "command": "bjorn-code.toggleConnection.connected",
                "icon": "$(circle-filled)"
            },
            {
                "title": "Bjorn Code: Syncing...",
                "command": "bjorn-code.toggleConnection.syncing",
                "icon": "$(sync~spin)"
            },
            {
                "title": "Bjorn Code: Disconnected",
                "command": "bjorn-code.toggleConnection.disconnected",
                "icon": "$(debug-disconnect)"
            },
            {
                "title": "Bjorn Code: Error",
                "command": "bjorn-code.toggleConnection.error",
                "icon": "$(error)"
            },
            {
                "title": "Bjorn Code: Pull from Remote",
                "command": "bjorn-code.syncPull",
                "icon": "$(cloud-download)"
            },
            {
                "title": "Bjorn Code: Open Settings",
                "command": "bjorn-code.openSettings",
                "icon": "$(settings-gear)"
            },
            {
                "command": "bjorn-code.openFile",
                "title": "Bjorn Code: Open File"
            },
            {
                "command": "bjorn-code.toggleAutoSync",
                "title": "Bjorn Code: Toggle Auto-Sync"
            },
            {
                "title": "Bjorn Code: Toggle ON/OFF",
                "command": "bjorn-code.toggleEnabled",
                "icon": "$(power)"
            },
            {
                "title": "Bjorn Code: Status Actions",
                "command": "bjorn-code.statusActions",
                "icon": "$(pulse)"
            },
            {
                "title": "Bjorn Code: Sync This File/Folder",
                "command": "bjorn-code.syncResource",
                "icon": "$(cloud-upload)"
            },
            {
                "title": "Bjorn Code: Download Remote Version",
                "command": "bjorn-code.downloadResource",
                "icon": "$(cloud-download)"
            },
            {
                "title": "Bjorn Code: Compare with Remote",
                "command": "bjorn-code.diffWithRemote",
                "icon": "$(diff)"
            },
            {
                "command": "bjorn-code.addInclude",
                "title": "Bjorn Code: Add to Sync Scope (include)"
            },
            {
                "command": "bjorn-code.addExclusion",
                "title": "Bjorn Code: Exclude from Sync"
            },
            {
                "title": "Bjorn Code: Run Python File Remotely",
                "command": "bjorn-code.runPythonRemote",
                "icon": "$(play-circle)"
            },
            {
                "command": "bjorn-code.service.start",
                "title": "Bjorn Code: Service Start"
            },
            {
                "command": "bjorn-code.service.stop",
                "title": "Bjorn Code: Service Stop"
            },
            {
                "command": "bjorn-code.service.restart",
                "title": "Bjorn Code: Service Restart"
            },
            {
                "command": "bjorn-code.service.status",
                "title": "Bjorn Code: Service Status"
            },
            {
                "command": "bjorn-code.service.enable",
                "title": "Bjorn Code: Service Enable"
            },
            {
                "command": "bjorn-code.service.disable",
                "title": "Bjorn Code: Service Disable"
            },
            {
                "command": "bjorn-code.service.tail",
                "title": "Bjorn Code: Tail Service Logs"
            },
            {
                "command": "bjorn-code.openConflictsView",
                "title": "Bjorn Code: Open Conflicts"
            },
            {
                "command": "bjorn-code.renameResource",
                "title": "Bjorn Code: Rename"
            },
            {
                "command": "bjorn-code.deleteResource",
                "title": "Bjorn Code: Delete"
            },
            {
                "command": "bjorn-code.newFile",
                "title": "Bjorn Code: New File"
            },
            {
                "command": "bjorn-code.newFolder",
                "title": "Bjorn Code: New Folder"
            },
            {
                "command": "bjorn-code.importIntoFolder",
                "title": "Bjorn Code: Import Here"
            },
            {
                "command": "bjorn-code.openView",
                "title": "Bjorn Code: Open View",
                "icon": "$(sidebar-left)"
            },
            {
                "title": "Bjorn Code: Restart Bjorn Service",
                "command": "bjorn-code.restartBjorn",
                "icon": "$(debug-restart)"
            },
            {
                "title": "Bjorn Code: Reboot Pi",
                "command": "bjorn-code.rebootPi",
                "icon": "$(vm-connect)"
            },
            {
                "title": "Bjorn Code: SSH Terminal",
                "command": "bjorn-code.openSshTerminal",
                "icon": "$(terminal)"
            },
            {
                "title": "Bjorn Code: Live Logs Panel",
                "command": "bjorn-code.openLiveLogs",
                "icon": "$(open-preview)"
            },
            {
                "title": "Bjorn Code: Sync Summary",
                "command": "bjorn-code.syncSummary",
                "icon": "$(list-flat)"
            }
        ],
        "configuration": {
            "title": "Bjorn Code",
            "properties": {
                "bjornCode.remoteIp": {
                    "type": "string",
                    "default": "192.168.1.15",
                    "description": "IP address of the Raspberry Pi"
                },
                "bjornCode.username": {
                    "type": "string",
                    "default": "bjorn",
                    "description": "SSH username"
                },
                "bjornCode.password": {
                    "type": "string",
                    "default": "bjorn",
                    "description": "SSH password"
                },
                "bjornCode.remotePath": {
                    "type": "string",
                    "default": "/home/bjorn/Bjorn",
                    "description": "Remote path on the Raspberry Pi"
                },
                "bjornCode.localPath": {
                    "type": "string",
                    "default": "",
                    "description": "Local path to sync (leave empty to use current workspace root)"
                },
                "bjornCode.privateKeyPath": {
                    "type": "string",
                    "default": "~/.ssh/id_rsa",
                    "description": "Path to your private SSH key (e.g., C:/Users/Name/.ssh/id_rsa)"
                },
                "bjornCode.autoSync": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable automatic synchronization on file change"
                },
                "bjornCode.enabled": {
                    "type": "boolean",
                    "default": false,
                    "description": "Master switch to enable or disable Bjorn Code synchronization"
                },
                "bjornCode.exclusions": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        ".git",
                        "node_modules",
                        ".DS_Store",
                        "out",
                        "*.vsix",
                        "__pycache__",
                        "*.pyc",
                        "*.db",
                        "*.db-shm",
                        "*.db-wal",
                        ".lgd-nfy0"
                    ],
                    "description": "List of files or directories to exclude from synchronization"
                },
                "bjornCode.port": {
                    "type": "number",
                    "default": 22,
                    "description": "SSH port"
                },
                "bjornCode.includes": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "**/*"
                    ],
                    "description": "Selective sync include globs"
                },
                "bjornCode.syncMode": {
                    "type": "string",
                    "enum": [
                        "mirror",
                        "selective"
                    ],
                    "default": "mirror",
                    "description": "Mirror all files or only includes"
                },
                "bjornCode.maxConcurrency": {
                    "type": "number",
                    "default": 3,
                    "minimum": 1,
                    "maximum": 10,
                    "description": "Maximum parallel transfers"
                },
                "bjornCode.maxRetries": {
                    "type": "number",
                    "default": 3,
                    "minimum": 0,
                    "maximum": 10,
                    "description": "Retries per transfer job"
                },
                "bjornCode.connectTimeoutMs": {
                    "type": "number",
                    "default": 20000,
                    "minimum": 1000,
                    "description": "SSH connect timeout in milliseconds"
                },
                "bjornCode.operationTimeoutMs": {
                    "type": "number",
                    "default": 30000,
                    "minimum": 1000,
                    "description": "SFTP operation timeout in milliseconds"
                },
                "bjornCode.pollingIntervalSec": {
                    "type": "number",
                    "default": 10,
                    "minimum": 1,
                    "description": "Polling interval for remote change detection (seconds)"
                },
                "bjornCode.pythonPath": {
                    "type": "string",
                    "default": "/usr/bin/python3",
                    "description": "Remote python interpreter path"
                },
                "bjornCode.sudoByDefault": {
                    "type": "boolean",
                    "default": false,
                    "description": "Use sudo by default when running remote commands"
                },
                "bjornCode.services": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "List of systemd services available in commands"
                },
                "bjornCode.logLevel": {
                    "type": "string",
                    "enum": [
                        "debug",
                        "info",
                        "warn",
                        "error"
                    ],
                    "default": "info",
                    "description": "Log verbosity level"
                },
                "bjornCode.bjornServiceName": {
                    "type": "string",
                    "default": "bjorn",
                    "description": "Name of the Bjorn systemd service for quick restart"
                }
            }
        },
        "menus": {
            "view/item/context": [
                {
                    "group": "inline@1",
                    "command": "bjorn-code.syncResource",
                    "when": "view == bjornCodeExplorer && viewItem =~ /bjornFile|bjornFolder/"
                },
                {
                    "group": "inline@2",
                    "command": "bjorn-code.downloadResource",
                    "when": "view == bjornCodeExplorer && viewItem =~ /bjornFile|bjornFolder/"
                },
                {
                    "group": "inline@3",
                    "command": "bjorn-code.diffWithRemote",
                    "when": "view == bjornCodeExplorer && viewItem == bjornFile"
                },
                {
                    "group": "navigation@1",
                    "command": "bjorn-code.diffWithRemote",
                    "when": "view == bjornCodeExplorer && viewItem == bjornFile"
                },
                {
                    "group": "navigation@2",
                    "command": "bjorn-code.addInclude",
                    "when": "view == bjornCodeExplorer && viewItem =~ /bjornFile|bjornFolder/"
                },
                {
                    "group": "navigation@3",
                    "command": "bjorn-code.addExclusion",
                    "when": "view == bjornCodeExplorer && viewItem =~ /bjornFile|bjornFolder/"
                },
                {
                    "group": "navigation@4",
                    "command": "bjorn-code.renameResource",
                    "when": "view == bjornCodeExplorer && viewItem =~ /bjornFile|bjornFolder/"
                },
                {
                    "group": "navigation@5",
                    "command": "bjorn-code.deleteResource",
                    "when": "view == bjornCodeExplorer && viewItem =~ /bjornFile|bjornFolder/"
                },
                {
                    "group": "navigation@6",
                    "command": "bjorn-code.newFile",
                    "when": "view == bjornCodeExplorer && viewItem =~ /bjornFolder|bjornWorkspaceRoot/"
                },
                {
                    "group": "navigation@7",
                    "command": "bjorn-code.newFolder",
                    "when": "view == bjornCodeExplorer && viewItem =~ /bjornFolder|bjornWorkspaceRoot/"
                },
                {
                    "group": "navigation@8",
                    "command": "bjorn-code.importIntoFolder",
                    "when": "view == bjornCodeExplorer && viewItem =~ /bjornFolder|bjornWorkspaceRoot/"
                },
                {
                    "group": "inline@1",
                    "command": "bjorn-code.runPythonRemote",
                    "when": "view == bjornCodeExplorer && viewItem == bjornToolRunPython"
                },
                {
                    "group": "inline@1",
                    "command": "bjorn-code.openSshTerminal",
                    "when": "view == bjornCodeExplorer && viewItem == bjornToolSshTerminal"
                },
                {
                    "group": "inline@1",
                    "command": "bjorn-code.restartBjorn",
                    "when": "view == bjornCodeExplorer && viewItem == bjornToolRestartService"
                },
                {
                    "group": "inline@1",
                    "command": "bjorn-code.rebootPi",
                    "when": "view == bjornCodeExplorer && viewItem == bjornToolReboot"
                },
                {
                    "group": "inline@2",
                    "command": "bjorn-code.service.status",
                    "when": "view == bjornCodeExplorer && viewItem == bjornToolServiceStatus"
                },
                {
                    "group": "inline@3",
                    "command": "bjorn-code.service.tail",
                    "when": "view == bjornCodeExplorer && viewItem == bjornToolServiceTail"
                },
                {
                    "group": "inline@1",
                    "command": "bjorn-code.openLiveLogs",
                    "when": "view == bjornCodeExplorer && viewItem == bjornToolLiveLogs"
                }
            ],
            "view/title": [
                {
                    "group": "navigation@1",
                    "command": "bjorn-code.toggleEnabled",
                    "when": "view == bjornCodeExplorer"
                },
                {
                    "group": "navigation@2",
                    "command": "bjorn-code.toggleConnection.connected",
                    "when": "view == bjornCodeExplorer && bjornCode.state == 'connected'"
                },
                {
                    "group": "navigation@2",
                    "command": "bjorn-code.toggleConnection.syncing",
                    "when": "view == bjornCodeExplorer && bjornCode.state == 'syncing'"
                },
                {
                    "group": "navigation@2",
                    "command": "bjorn-code.toggleConnection.disconnected",
                    "when": "view == bjornCodeExplorer && bjornCode.state == 'disconnected'"
                },
                {
                    "group": "navigation@2",
                    "command": "bjorn-code.toggleConnection.error",
                    "when": "view == bjornCodeExplorer && bjornCode.state == 'error'"
                },
                {
                    "group": "navigation@2",
                    "command": "bjorn-code.toggleConnection",
                    "when": "view == bjornCodeExplorer && bjornCode.state == 'connecting'"
                },
                {
                    "group": "navigation@3",
                    "command": "bjorn-code.syncNow",
                    "when": "view == bjornCodeExplorer"
                },
                {
                    "group": "navigation@4",
                    "command": "bjorn-code.syncPull",
                    "when": "view == bjornCodeExplorer"
                },
                {
                    "group": "navigation@5",
                    "command": "bjorn-code.openSettings",
                    "when": "view == bjornCodeExplorer"
                }
            ],
            "explorer/context": [
                {
                    "command": "bjorn-code.syncResource",
                    "group": "navigation@1"
                },
                {
                    "command": "bjorn-code.downloadResource",
                    "group": "navigation@2"
                },
                {
                    "command": "bjorn-code.diffWithRemote",
                    "group": "navigation@3"
                },
                {
                    "command": "bjorn-code.addInclude",
                    "group": "navigation@4"
                },
                {
                    "command": "bjorn-code.addExclusion",
                    "group": "navigation@5"
                },
                {
                    "command": "bjorn-code.runPythonRemote",
                    "group": "navigation@6"
                }
            ],
            "editor/title": [
                {
                    "command": "bjorn-code.diffWithRemote",
                    "group": "navigation",
                    "when": "bjornCode.enabled && bjornCode.connected"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "bjorn-code",
                    "title": "Bjorn Code",
                    "icon": "img/bjorn.svg"
                }
            ]
        },
        "views": {
            "bjorn-code": [
                {
                    "id": "bjornCodeExplorer",
                    "name": "Sync Controls"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "dependencies": {
        "ssh2": "^1.11.0"
    },
    "bundledDependencies": [
        "ssh2",
        "asn1",
        "bcrypt-pbkdf",
        "buildcheck",
        "cpu-features",
        "nan",
        "safer-buffer",
        "tweetnacl"
    ],
    "devDependencies": {
        "@types/node": "^18.11.18",
        "@types/ssh2": "^1.11.7",
        "@types/vscode": "^1.75.0",
        "typescript": "^4.9.5"
    }
}
